function AuthScreen({ onLogin }) {
  const [mode, setMode] = useState("login"); // login | signup | pending
  const [f, setF] = useState({ first: "", last: "", email: "", pw: "", pw2: "" });
  const [err, setErr] = useState("");
  const [pendingEmail, setPendingEmail] = useState("");
  const [loading, setLoading] = useState(false);

  const set = (k, v) => setF({ ...f, [k]: v });

  const handleSignup = async () => {
    setErr("");
    if (!f.first || !f.last || !f.email || !f.pw) return setErr("Tous les champs sont obligatoires.");
    if (f.pw.length < 6) return setErr("Le mot de passe doit faire au moins 6 caractères.");
    if (f.pw !== f.pw2) return setErr("Les mots de passe ne correspondent pas.");
    setLoading(true);
    const existing = await load(`user:${f.email.toLowerCase()}`);
    if (existing) { setLoading(false); return setErr("Un compte existe déjà avec cet email."); }
    const user = {
      first: f.first, last: f.last, email: f.email.toLowerCase(),
      pwHash: hashPw(f.pw), status: "pending",
      createdAt: new Date().toISOString(),
    };
    await store(`user:${user.email}`, user);
    setLoading(false);
    setPendingEmail(user.email);
    setMode("pending");
  };

  const handleLogin = async () => {
    setErr("");
    if (!f.email || !f.pw) return setErr("Email et mot de passe requis.");
    setLoading(true);
    // Admin login
    if (f.email.toLowerCase() === ADMIN_EMAIL && hashPw(f.pw) === ADMIN_PW_HASH) {
      setLoading(false);
      onLogin({ email: ADMIN_EMAIL, first: "Admin", last: "", isAdmin: true });
      return;
    }
    const user = await load(`user:${f.email.toLowerCase()}`);
    if (!user || user.pwHash !== hashPw(f.pw)) { setLoading(false); return setErr("Email ou mot de passe incorrect."); }
    if (user.status === "pending") { setLoading(false); setPendingEmail(user.email); return setMode("pending"); }
    if (user.status === "rejected") { setLoading(false); return setErr("Votre accès a été refusé par l'administrateur."); }
    if (user.status === "disabled") { setLoading(false); return setErr("Votre compte a été désactivé. Contactez l'administrateur."); }
    setLoading(false);
    onLogin(user);
  };

  const refreshPending = async () => {
    if (!pendingEmail) return;
    setLoading(true);
    const user = await load(`user:${pendingEmail}`);
    setLoading(false);
    if (user?.status === "approved") onLogin(user);
    else if (user?.status === "rejected") { setErr("Votre accès a été refusé."); setMode("login"); }
    else setErr("Toujours en attente de validation…");
  };

  return (
    <div className="auth-shell">
      <div className="auth-left">
        <div className="auth-left-inner">
          <h1 className="auth-brand">OfferForge</h1>
          <p className="auth-tagline">Crée une offre irrésistible en quelques heures, même sans aucune expérience en business.</p>
          <div className="auth-features">
            {["9 modules guidés par l'IA", "De zéro à une offre vendable", "Recommandations personnalisées", "Résultat prêt à vendre"].map((t, i) => (
              <div key={i} className="auth-feature"><span className="auth-check">✦</span>{t}</div>
            ))}
          </div>
        </div>
      </div>
      <div className="auth-right">
        <div className="auth-card">
          {mode === "pending" ? (
            <>
              <div className="auth-pending-icon">⏳</div>
              <h2 className="auth-title">Compte en attente</h2>
              <p className="auth-subtitle">Votre compte a bien été créé. Il est actuellement en attente de validation par l'administrateur.</p>
              <p style={{ fontSize: 13, color: "#606090", marginTop: 16, lineHeight: 1.6 }}>
                Vous recevrez l'accès dès que l'administrateur aura validé votre inscription. Vous pouvez vérifier votre statut ci-dessous.
              </p>
              {err && <div className="auth-err">{err}</div>}
              <Btn onClick={refreshPending} disabled={loading} style={{ marginTop: 24, width: "100%" }}>
                {loading ? "Vérification..." : "🔄 Vérifier mon statut"}
              </Btn>
              <Btn variant="ghost" onClick={() => { setMode("login"); setErr(""); }} style={{ marginTop: 12, width: "100%" }}>
                ← Retour à la connexion
              </Btn>
            </>
          ) : (
            <>
              <h2 className="auth-title">{mode === "login" ? "Connexion" : "Créer un compte"}</h2>
              <p className="auth-subtitle">{mode === "login" ? "Connecte-toi pour accéder à ton espace" : "Inscris-toi pour commencer"}</p>

              {mode === "signup" && (
                <div className="auth-row">
                  <Input value={f.first} onChange={(v) => set("first", v)} placeholder="Prénom" icon="👤" />
                  <Input value={f.last} onChange={(v) => set("last", v)} placeholder="Nom" icon="📛" />
                </div>
              )}
              <Input type="email" value={f.email} onChange={(v) => set("email", v)} placeholder="Email" icon="✉" />
              <Input type="password" value={f.pw} onChange={(v) => set("pw", v)} placeholder="Mot de passe" icon="🔒" />
              {mode === "signup" && (
                <Input type="password" value={f.pw2} onChange={(v) => set("pw2", v)} placeholder="Confirmer le mot de passe" icon="🔒" />
              )}

              {err && <div className="auth-err">{err}</div>}

              <Btn onClick={mode === "login" ? handleLogin : handleSignup} disabled={loading} style={{ width: "100%", marginTop: 20 }}>
                {loading ? "Chargement..." : mode === "login" ? "Se connecter →" : "Créer mon compte →"}
              </Btn>

              <p className="auth-toggle">
                {mode === "login" ? "Pas encore de compte ?" : "Déjà inscrit ?"}
                <button className="auth-link" onClick={() => { setMode(mode === "login" ? "signup" : "login"); setErr(""); }}>
                  {mode === "login" ? "S'inscrire" : "Se connecter"}
                </button>
              </p>
            </>
          )}
        </div>
      </div>
    </div>
  );
}

