export default function App() {
  const [user, setUser] = useState(null);
  const [checking, setChecking] = useState(true);

  useEffect(() => {
    (async () => {
      const sess = await load("session:current");
      if (sess) setUser(sess);
      setChecking(false);
    })();
  }, []);

  const login = async (u) => {
    setUser(u);
    await store("session:current", u);
  };
  const logout = async () => {
    setUser(null);
    await remove("session:current");
  };

  if (checking) return <div className="app-shell"><Loader text="Chargement..."/></div>;
  if (!user) return <><GlobalStyles/><AuthScreen onLogin={login}/></>;
  if (user.isAdmin) return <><GlobalStyles/><AdminPanel onLogout={logout}/></>;
  return <><GlobalStyles/><OfferBuilder user={user} onLogout={logout}/></>;
}

