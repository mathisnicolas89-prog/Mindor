  const [moduleData, setModuleData] = useState(Array(9).fill(null).map(()=>({})));
  const [aiResults, setAiResults] = useState(Array(7).fill(""));
  const [loaded, setLoaded] = useState(false);
  const contentRef = useRef(null);

  // Load saved progress
  useEffect(() => {
    (async () => {
      const saved = await load(`data:${user.email}`);
      if (saved) {
        if (saved.moduleData) setModuleData(saved.moduleData);
        if (saved.aiResults) setAiResults(saved.aiResults);
        if (saved.step !== undefined) setStep(saved.step);
      }
      setLoaded(true);
    })();
  }, []);

  // Auto-save
  useEffect(() => {
    if (!loaded) return;
    store(`data:${user.email}`, { moduleData, aiResults, step });
  }, [moduleData, aiResults, step, loaded]);

  const setMD = (i) => (d) => { const c=[...moduleData]; c[i]=d; setModuleData(c); };
  const setAR = (i) => (r) => { const c=[...aiResults]; c[i]=r; setAiResults(c); };

  useEffect(() => { contentRef.current?.scrollTo({top:0,behavior:"smooth"}); }, [step]);

  const progress = ((step+1)/9)*100;
  const canNext = () => {
    if (step===0) return !!(moduleData[0].skills && moduleData[0].goal);
    if (step===1) return !!(moduleData[1].who && moduleData[1].pains);
    return true;
  };

  const renderModule = () => {
    if (step===0) return <Module0 data={moduleData[0]} setData={setMD(0)}/>;
    if (step===1) return <Module1 data={moduleData[1]} setData={setMD(1)}/>;
    const ai = step-2;
    const m = AI_MODULES[ai];
    return <AIModule title={m.title} desc={m.desc} prompt={m.prompt}
      contextBuilder={()=>m.ctx(moduleData)+(ai>0?`\nRÉSULTATS PRÉCÉDENTS:\n${aiResults.slice(0,ai).filter(Boolean).join("\n---\n")}`:"")}
      allData={moduleData} result={aiResults[ai]} setResult={setAR(ai)} />;
  };

  if (!loaded) return <div className="app-shell"><Loader text="Chargement de ta progression..."/></div>;

  return (
    <div className="app-shell">
      <aside className="sidebar">
        <div className="sidebar-brand">
          <h1>OfferForge</h1>
          <p>CRÉATEUR D'OFFRES</p>
        </div>
        <div className="sidebar-user">
          <div className="user-avatar">{user.first[0]}</div>
          <div>
            <div style={{fontSize:13,fontWeight:600,color:"#c0c0d0"}}>{user.first} {user.last}</div>
            <div style={{fontSize:11,color:"#505070"}}>{user.email}</div>
          </div>
        </div>
        <div className="sidebar-nav">
          {MODULES.map((m,i)=>(
            <div key={i} className={`nav-item ${step===i?"active":""} ${i<step?"done":""}`} onClick={()=>i<=step&&setStep(i)}>
              <div className="nav-icon">{i<step?"✓":m.icon}</div>
              <div><div className="nav-title">{m.title}</div><div className="nav-sub">{m.sub}</div></div>
            </div>
          ))}
        </div>
        <div style={{marginTop:"auto",padding:"16px 24px"}}>
          <Btn variant="ghost" onClick={onLogout} style={{width:"100%",fontSize:12}}>🔓 Déconnexion</Btn>
        </div>
      </aside>
      <main className="main-area">
        <div className="top-bar">
          <span className="top-bar-title">Module {step+1} / 9</span>
          <div style={{display:"flex",alignItems:"center",gap:16}}>
            <div className="progress-bar-bg"><div className="progress-bar-fill" style={{width:`${progress}%`}}/></div>
            <ProgressRing value={progress}/>
          </div>
        </div>
        <div className="content-scroll" ref={contentRef}>{renderModule()}</div>
        <div className="bottom-nav">
          <Btn variant="secondary" onClick={()=>setStep(step-1)} disabled={step===0}>← Précédent</Btn>
          <Btn onClick={()=>setStep(step+1)} disabled={step===8||!canNext()}>
            {step===7?"Voir le résultat final →":"Suivant →"}
          </Btn>
        </div>
      </main>
    </div>
  );
}

