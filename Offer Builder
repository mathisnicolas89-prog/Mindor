//  ADMIN PANEL
// ═══════════════════════════════════════════
function AdminPanel({ onLogout }) {
  const [users, setUsers] = useState([]);
  const [loading, setLoading] = useState(true);
  const [filter, setFilter] = useState("all");

  const loadUsers = async () => {
    setLoading(true);
    const keys = await listKeys("user:");
    const all = [];
    for (const k of keys) {
      const u = await load(k);
      if (u && u.email !== ADMIN_EMAIL) all.push(u);
    }
    all.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
    setUsers(all);
    setLoading(false);
  };

  useEffect(() => { loadUsers(); }, []);

  const updateStatus = async (email, status) => {
    const u = await load(`user:${email}`);
    if (u) { u.status = status; await store(`user:${email}`, u); }
    loadUsers();
  };

  const deleteUser = async (email) => {
    await remove(`user:${email}`);
    // Also remove their module data
    await remove(`data:${email}`);
    loadUsers();
  };

  const filtered = filter === "all" ? users : users.filter((u) => u.status === filter);
  const counts = { all: users.length, pending: users.filter((u) => u.status === "pending").length, approved: users.filter((u) => u.status === "approved").length };

  return (
    <div className="admin-shell">
      <div className="admin-header">
        <div>
          <h1 className="admin-brand">OfferForge <span className="admin-badge">ADMIN</span></h1>
          <p style={{ fontSize: 13, color: "#606090", marginTop: 4 }}>Gestion des utilisateurs et des accès</p>
        </div>
        <Btn variant="ghost" onClick={onLogout}>Déconnexion</Btn>
      </div>

      <div className="admin-stats">
        {[["all", "Total", counts.all, "#8080c0"], ["pending", "En attente", counts.pending, "#f0c040"], ["approved", "Approuvés", counts.approved, "#4ade80"]].map(([key, label, count, color]) => (
          <div key={key} className={`stat-card ${filter === key ? "stat-active" : ""}`} onClick={() => setFilter(key)}>
            <div className="stat-count" style={{ color }}>{count}</div>
            <div className="stat-label">{label}</div>
          </div>
        ))}
      </div>

      <div className="admin-table-wrap">
        {loading ? <Loader text="Chargement des utilisateurs..." /> : filtered.length === 0 ? (
          <div style={{ textAlign: "center", padding: 60, color: "#606090" }}>
            <p style={{ fontSize: 40, marginBottom: 12 }}>📭</p>
            <p>Aucun utilisateur {filter !== "all" ? `avec le statut "${filter}"` : ""}</p>
          </div>
        ) : (
          <table className="admin-table">
            <thead>
              <tr>
                <th>Utilisateur</th>
                <th>Email</th>
                <th>Inscription</th>
                <th>Statut</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {filtered.map((u) => (
                <tr key={u.email}>
                  <td style={{ fontWeight: 600 }}>{u.first} {u.last}</td>
                  <td style={{ color: "#808098" }}>{u.email}</td>
                  <td style={{ color: "#606090", fontSize: 12 }}>{new Date(u.createdAt).toLocaleDateString("fr-FR")}</td>
                  <td><StatusBadge status={u.status} /></td>
                  <td>
                    <div className="action-btns">
                      {u.status !== "approved" && (
                        <button className="act-btn act-approve" onClick={() => updateStatus(u.email, "approved")} title="Approuver">✓</button>
                      )}
                      {u.status === "approved" && (
                        <button className="act-btn act-disable" onClick={() => updateStatus(u.email, "disabled")} title="Désactiver">⏸</button>
                      )}
                      {u.status !== "rejected" && u.status !== "approved" && (
                        <button className="act-btn act-reject" onClick={() => updateStatus(u.email, "rejected")} title="Refuser">✕</button>
                      )}
                      {u.status === "disabled" && (
                        <button className="act-btn act-approve" onClick={() => updateStatus(u.email, "approved")} title="Réactiver">↻</button>
                      )}
                      <button className="act-btn act-delete" onClick={() => { if (confirm(`Supprimer ${u.first} ${u.last} ?`)) deleteUser(u.email); }} title="Supprimer">🗑</button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>
      <Btn variant="secondary" onClick={loadUsers} style={{ margin: "16px 32px" }}>🔄 Rafraîchir</Btn>
    </div>
  );
}

